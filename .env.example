# Notion API token — from https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The ID of your "Task Database" in Notion
# Found in the database URL: notion.so/<workspace>/<DATABASE_ID>?v=...
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# A random secret used to authenticate Vercel cron requests
# Generate with: openssl rand -hex 32
CRON_SECRET=your_random_secret_here
